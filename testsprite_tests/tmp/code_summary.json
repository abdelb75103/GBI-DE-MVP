{
  "tech_stack": [
    "TypeScript",
    "Next.js 16.0.0",
    "React 19.2.0",
    "Node.js",
    "Supabase",
    "Google Generative AI (Gemini)",
    "TailwindCSS",
    "Zod"
  ],
  "features": [
    {
      "name": "Upload Paper",
      "description": "Upload PDF files (≤20MB) and create paper records with metadata (title, author, year, journal, DOI). Validates file size and stores file data.",
      "files": [
        "fifa-gbi-data-extraction/src/app/api/uploads/route.ts"
      ],
      "api_doc": {
        "openapi": "3.0.0",
        "info": {
          "title": "Upload Paper API",
          "version": "1.0.0"
        },
        "paths": {
          "/api/uploads": {
            "post": {
              "summary": "Upload a PDF file and create a paper record",
              "requestBody": {
                "content": {
                  "multipart/form-data": {
                    "schema": {
                      "type": "object",
                      "properties": {
                        "file": {
                          "type": "string",
                          "format": "binary",
                          "description": "PDF file (max 20MB)"
                        },
                        "title": {
                          "type": "string"
                        },
                        "leadAuthor": {
                          "type": "string"
                        },
                        "year": {
                          "type": "string"
                        },
                        "journal": {
                          "type": "string"
                        },
                        "doi": {
                          "type": "string"
                        }
                      },
                      "required": ["file"]
                    }
                  }
                }
              },
              "responses": {
                "201": {
                  "description": "Paper and file created successfully",
                  "content": {
                    "application/json": {
                      "schema": {
                        "type": "object",
                        "properties": {
                          "paper": {
                            "$ref": "#/components/schemas/Paper"
                          },
                          "file": {
                            "$ref": "#/components/schemas/StoredFile"
                          }
                        }
                      }
                    }
                  }
                },
                "400": {
                  "description": "Invalid request (missing file or file too large)"
                }
              }
            }
          }
        }
      }
    },
    {
      "name": "List Papers",
      "description": "Get a list of all papers with their status and metadata. Supports filtering and search.",
      "files": [
        "fifa-gbi-data-extraction/src/app/api/papers/route.ts"
      ],
      "api_doc": {
        "openapi": "3.0.0",
        "paths": {
          "/api/papers": {
            "get": {
              "summary": "List all papers",
              "responses": {
                "200": {
                  "description": "List of papers",
                  "content": {
                    "application/json": {
                      "schema": {
                        "type": "object",
                        "properties": {
                          "papers": {
                            "type": "array",
                            "items": {
                              "$ref": "#/components/schemas/Paper"
                            }
                          }
                        }
                      }
                    }
                  }
                }
              }
            },
            "post": {
              "summary": "Create a new paper",
              "requestBody": {
                "content": {
                  "application/json": {
                    "schema": {
                      "type": "object",
                      "properties": {
                        "title": {
                          "type": "string",
                          "required": true
                        },
                        "leadAuthor": {
                          "type": "string"
                        },
                        "year": {
                          "type": "string"
                        },
                        "journal": {
                          "type": "string"
                        },
                        "doi": {
                          "type": "string"
                        },
                        "status": {
                          "type": "string",
                          "enum": ["uploaded", "processing", "extracted", "flagged", "qa_review", "archived"]
                        }
                      }
                    }
                  }
                }
              },
              "responses": {
                "201": {
                  "description": "Paper created"
                },
                "400": {
                  "description": "Title is required"
                }
              }
            }
          }
        }
      }
    },
    {
      "name": "Get/Update Paper",
      "description": "Retrieve a specific paper by ID or update paper metadata.",
      "files": [
        "fifa-gbi-data-extraction/src/app/api/papers/[paperId]/route.ts"
      ],
      "api_doc": {
        "openapi": "3.0.0",
        "paths": {
          "/api/papers/{paperId}": {
            "get": {
              "summary": "Get paper by ID",
              "parameters": [
                {
                  "name": "paperId",
                  "in": "path",
                  "required": true,
                  "schema": {
                    "type": "string"
                  }
                }
              ],
              "responses": {
                "200": {
                  "description": "Paper details"
                },
                "404": {
                  "description": "Paper not found"
                }
              }
            },
            "patch": {
              "summary": "Update paper metadata",
              "parameters": [
                {
                  "name": "paperId",
                  "in": "path",
                  "required": true,
                  "schema": {
                    "type": "string"
                  }
                }
              ],
              "requestBody": {
                "content": {
                  "application/json": {
                    "schema": {
                      "type": "object",
                      "properties": {
                        "title": {
                          "type": "string"
                        },
                        "leadAuthor": {
                          "type": "string"
                        },
                        "year": {
                          "type": "string"
                        },
                        "journal": {
                          "type": "string"
                        },
                        "doi": {
                          "type": "string"
                        },
                        "status": {
                          "type": "string"
                        }
                      }
                    }
                  }
                }
              },
              "responses": {
                "200": {
                  "description": "Paper updated"
                },
                "404": {
                  "description": "Paper not found"
                }
              }
            }
          }
        }
      }
    },
    {
      "name": "Extract Data",
      "description": "AI-powered extraction of data from PDF papers using Google Gemini API. Extracts fields for specific tabs (study details, participant characteristics, definitions, exposure).",
      "files": [
        "fifa-gbi-data-extraction/src/app/api/extract/route.ts"
      ],
      "api_doc": {
        "openapi": "3.0.0",
        "paths": {
          "/api/extract": {
            "post": {
              "summary": "Extract data from paper using AI",
              "requestBody": {
                "content": {
                  "application/json": {
                    "schema": {
                      "type": "object",
                      "properties": {
                        "paperId": {
                          "type": "string",
                          "required": true
                        },
                        "tab": {
                          "type": "string",
                          "enum": ["studyDetails", "participantCharacteristics", "definitions", "exposure"],
                          "required": true
                        },
                        "fields": {
                          "type": "array",
                          "items": {
                            "type": "string"
                          },
                          "required": true,
                          "minItems": 1
                        },
                        "apiKey": {
                          "type": "string",
                          "required": true,
                          "description": "Google Gemini API key"
                        }
                      },
                      "required": ["paperId", "tab", "fields", "apiKey"]
                    }
                  }
                }
              },
              "responses": {
                "200": {
                  "description": "Extraction completed",
                  "content": {
                    "application/json": {
                      "schema": {
                        "type": "object",
                        "properties": {
                          "paperId": {
                            "type": "string"
                          },
                          "tab": {
                            "type": "string"
                          },
                          "model": {
                            "type": "string"
                          },
                          "fields": {
                            "type": "array",
                            "items": {
                              "type": "object",
                              "properties": {
                                "fieldId": {
                                  "type": "string"
                                },
                                "value": {
                                  "type": "string"
                                },
                                "confidence": {
                                  "type": "number"
                                },
                                "sourceQuote": {
                                  "type": "string"
                                },
                                "pageHint": {
                                  "type": "string"
                                },
                                "metric": {
                                  "type": "string"
                                }
                              }
                            }
                          }
                        }
                      }
                    }
                  }
                },
                "400": {
                  "description": "Invalid request or AI extraction not available for this tab"
                },
                "404": {
                  "description": "Paper not found"
                },
                "500": {
                  "description": "Extraction failed"
                }
              }
            }
          }
        }
      }
    },
    {
      "name": "Update Extraction Field",
      "description": "Update a specific extraction field value, status, confidence, or metadata for a paper.",
      "files": [
        "fifa-gbi-data-extraction/src/app/api/extract/field/route.ts"
      ],
      "api_doc": {
        "openapi": "3.0.0",
        "paths": {
          "/api/extract/field": {
            "put": {
              "summary": "Update extraction field",
              "requestBody": {
                "content": {
                  "application/json": {
                    "schema": {
                      "type": "object",
                      "properties": {
                        "paperId": {
                          "type": "string",
                          "required": true
                        },
                        "tab": {
                          "type": "string",
                          "required": true
                        },
                        "fieldId": {
                          "type": "string",
                          "required": true
                        },
                        "value": {
                          "type": "string",
                          "nullable": true
                        },
                        "status": {
                          "type": "string",
                          "enum": ["reported", "not_reported", "uncertain"]
                        },
                        "confidence": {
                          "type": "number",
                          "minimum": 0,
                          "maximum": 100
                        },
                        "sourceQuote": {
                          "type": "string"
                        },
                        "pageHint": {
                          "type": "string"
                        },
                        "metric": {
                          "type": "string",
                          "enum": ["prevalence", "incidence", "burden", "severityMeanDays", "severityTotalDays"]
                        }
                      },
                      "required": ["paperId", "tab", "fieldId"]
                    }
                  }
                }
              },
              "responses": {
                "200": {
                  "description": "Field updated successfully"
                },
                "400": {
                  "description": "Invalid request"
                },
                "404": {
                  "description": "Paper not found"
                }
              }
            }
          }
        }
      }
    },
    {
      "name": "Save Extraction",
      "description": "Save extraction results for a paper after AI extraction or manual editing.",
      "files": [
        "fifa-gbi-data-extraction/src/app/api/extract/save/route.ts"
      ],
      "api_doc": {
        "openapi": "3.0.0",
        "paths": {
          "/api/extract/save": {
            "post": {
              "summary": "Save extraction results",
              "requestBody": {
                "content": {
                  "application/json": {
                    "schema": {
                      "type": "object",
                      "properties": {
                        "paperId": {
                          "type": "string",
                          "required": true
                        },
                        "tab": {
                          "type": "string",
                          "required": true
                        },
                        "fields": {
                          "type": "array",
                          "items": {
                            "type": "object"
                          }
                        }
                      }
                    }
                  }
                }
              },
              "responses": {
                "200": {
                  "description": "Extraction saved"
                },
                "400": {
                  "description": "Invalid request"
                }
              }
            }
          }
        }
      }
    },
    {
      "name": "Paper Notes",
      "description": "Add and retrieve notes for papers. Notes can be used for collaboration and documentation.",
      "files": [
        "fifa-gbi-data-extraction/src/app/api/papers/[paperId]/notes/route.ts"
      ],
      "api_doc": {
        "openapi": "3.0.0",
        "paths": {
          "/api/papers/{paperId}/notes": {
            "get": {
              "summary": "Get all notes for a paper",
              "parameters": [
                {
                  "name": "paperId",
                  "in": "path",
                  "required": true,
                  "schema": {
                    "type": "string"
                  }
                }
              ],
              "responses": {
                "200": {
                  "description": "List of notes",
                  "content": {
                    "application/json": {
                      "schema": {
                        "type": "object",
                        "properties": {
                          "notes": {
                            "type": "array",
                            "items": {
                              "type": "object",
                              "properties": {
                                "id": {
                                  "type": "string"
                                },
                                "paperId": {
                                  "type": "string"
                                },
                                "author": {
                                  "type": "string"
                                },
                                "body": {
                                  "type": "string"
                                },
                                "createdAt": {
                                  "type": "string"
                                }
                              }
                            }
                          }
                        }
                      }
                    }
                  }
                }
              }
            },
            "post": {
              "summary": "Add a note to a paper",
              "parameters": [
                {
                  "name": "paperId",
                  "in": "path",
                  "required": true,
                  "schema": {
                    "type": "string"
                  }
                }
              ],
              "requestBody": {
                "content": {
                  "application/json": {
                    "schema": {
                      "type": "object",
                      "properties": {
                        "author": {
                          "type": "string",
                          "required": true
                        },
                        "body": {
                          "type": "string",
                          "required": true
                        }
                      },
                      "required": ["author", "body"]
                    }
                  }
                }
              },
              "responses": {
                "201": {
                  "description": "Note created"
                },
                "400": {
                  "description": "Author and body are required"
                }
              }
            }
          }
        }
      }
    },
    {
      "name": "Flag Paper",
      "description": "Flag or unflag a paper with a reason. Used for quality assurance and review workflows.",
      "files": [
        "fifa-gbi-data-extraction/src/app/api/papers/[paperId]/flag/route.ts"
      ],
      "api_doc": {
        "openapi": "3.0.0",
        "paths": {
          "/api/papers/{paperId}/flag": {
            "post": {
              "summary": "Toggle flag status for a paper",
              "parameters": [
                {
                  "name": "paperId",
                  "in": "path",
                  "required": true,
                  "schema": {
                    "type": "string"
                  }
                }
              ],
              "requestBody": {
                "content": {
                  "application/json": {
                    "schema": {
                      "type": "object",
                      "properties": {
                        "reason": {
                          "type": "string",
                          "nullable": true,
                          "description": "Required when flagging, null to unflag"
                        }
                      }
                    }
                  }
                }
              },
              "responses": {
                "200": {
                  "description": "Flag status updated",
                  "content": {
                    "application/json": {
                      "schema": {
                        "type": "object",
                        "properties": {
                          "flagReason": {
                            "type": "string",
                            "nullable": true
                          }
                        }
                      }
                    }
                  }
                },
                "400": {
                  "description": "Reason is required to flag a paper"
                },
                "404": {
                  "description": "Paper not found"
                }
              }
            }
          }
        }
      }
    },
    {
      "name": "Paper Session",
      "description": "Manage editing sessions for papers. Tracks who is currently editing a paper to prevent conflicts.",
      "files": [
        "fifa-gbi-data-extraction/src/app/api/papers/[paperId]/session/route.ts"
      ],
      "api_doc": {
        "openapi": "3.0.0",
        "paths": {
          "/api/papers/{paperId}/session": {
            "post": {
              "summary": "Start, heartbeat, or end a paper editing session",
              "parameters": [
                {
                  "name": "paperId",
                  "in": "path",
                  "required": true,
                  "schema": {
                    "type": "string"
                  }
                }
              ],
              "requestBody": {
                "content": {
                  "application/json": {
                    "schema": {
                      "type": "object",
                      "properties": {
                        "action": {
                          "type": "string",
                          "enum": ["start", "heartbeat", "end"],
                          "required": true
                        }
                      },
                      "required": ["action"]
                    }
                  }
                }
              },
              "responses": {
                "200": {
                  "description": "Session updated"
                },
                "401": {
                  "description": "No active profile selected"
                },
                "409": {
                  "description": "Paper session conflict - another user is editing"
                }
              }
            }
          }
        }
      }
    },
    {
      "name": "Export Data",
      "description": "Export extracted data as CSV or JSON. Supports filtering by paper IDs.",
      "files": [
        "fifa-gbi-data-extraction/src/app/api/exports/route.ts",
        "fifa-gbi-data-extraction/src/app/api/papers/[paperId]/export/route.ts"
      ],
      "api_doc": {
        "openapi": "3.0.0",
        "paths": {
          "/api/exports": {
            "get": {
              "summary": "List all exports",
              "responses": {
                "200": {
                  "description": "List of exports"
                }
              }
            },
            "post": {
              "summary": "Create a new export",
              "requestBody": {
                "content": {
                  "application/json": {
                    "schema": {
                      "type": "object",
                      "properties": {
                        "kind": {
                          "type": "string",
                          "enum": ["csv", "json"],
                          "required": true
                        },
                        "paperIds": {
                          "type": "array",
                          "items": {
                            "type": "string"
                          },
                          "required": true,
                          "minItems": 1
                        }
                      },
                      "required": ["kind", "paperIds"]
                    }
                  }
                }
              },
              "responses": {
                "201": {
                  "description": "Export job created"
                },
                "400": {
                  "description": "kind and paperIds are required"
                }
              }
            }
          },
          "/api/exports/{exportId}/download": {
            "get": {
              "summary": "Download an export file",
              "parameters": [
                {
                  "name": "exportId",
                  "in": "path",
                  "required": true,
                  "schema": {
                    "type": "string"
                  }
                }
              ],
              "responses": {
                "200": {
                  "description": "Export file"
                }
              }
            }
          }
        }
      }
    },
    {
      "name": "Session Profile",
      "description": "Manage active user profile session. Used for authentication and tracking who performs actions.",
      "files": [
        "fifa-gbi-data-extraction/src/app/api/session/profile/route.ts"
      ],
      "api_doc": {
        "openapi": "3.0.0",
        "paths": {
          "/api/session/profile": {
            "post": {
              "summary": "Set or clear active profile",
              "requestBody": {
                "content": {
                  "application/json": {
                    "schema": {
                      "type": "object",
                      "properties": {
                        "profileId": {
                          "type": "string",
                          "nullable": true,
                          "description": "Profile ID to set, or null to clear"
                        }
                      }
                    }
                  }
                }
              },
              "responses": {
                "200": {
                  "description": "Profile set or cleared",
                  "content": {
                    "application/json": {
                      "schema": {
                        "type": "object",
                        "properties": {
                          "ok": {
                            "type": "boolean"
                          },
                          "profile": {
                            "type": "object",
                            "properties": {
                              "id": {
                                "type": "string"
                              },
                              "fullName": {
                                "type": "string"
                              },
                              "role": {
                                "type": "string"
                              }
                            }
                          }
                        }
                      }
                    }
                  }
                },
                "404": {
                  "description": "Profile not found"
                }
              }
            }
          }
        }
      }
    }
  ]
}

